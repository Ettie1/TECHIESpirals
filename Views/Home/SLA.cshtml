	<thead>
		<tr>
			<th style="border: none; padding: 0cm"><p>Monthly Uptime</p>
			</th>
			<th style="border: none; padding: 0cm"><p>Service Credit</p>
			</th>
		</tr>
	</thead>
	<tbody>
		<tr>
			<td style="border: none; padding: 0cm"><p>≥ 99.5%</p>
			</td>
			<td style="border: none; padding: 0cm"><p>No credit</p>
			</td>
		</tr>
		<tr>
