        <a href="/" class="text-xl font-bold">
          TECHIE<span class="text-emerald-600">Spirals</span>
        </a>
      </div>

      <!-- Desktop Navigation -->
      <nav class="hidden md:flex items-center gap-6 navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
        <a href="/" class="text-sm font-medium transition-colors hover:text-emerald-600">
          Home
        </a>
        <a href="/Home/About" class="text-sm font-medium transition-colors hover:text-emerald-600">
