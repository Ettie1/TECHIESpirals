        <a href="/Home/Services" class="text-sm font-medium transition-colors hover:text-emerald-600">
          Services
        </a>
        <a href="/Home/Contact" class="text-sm font-medium transition-colors hover:text-emerald-600">
          Contact
        </a>
        <a href="/Home/Contact" class="bg-emerald-600 hover:bg-emerald-700 text-white px-4 py-2 rounded-md text-sm font-medium">
          Get Started
        </a>
      </nav>

      <ul id="btnMobileMenu">
        <li><img src="~/lib/bootstrap-icons/menu-button.svg" /></li>
        <li class="menuItem text-sm font-medium transition-colors hover:text-emerald-600">Home</li>
        <li class="menuItem text-sm font-medium transition-colors hover:text-emerald-600">About</li>
        <li class="menuItem text-sm font-medium transition-colors hover:text-emerald-600">Services</li>
        <li class="menuItem text-sm font-medium transition-colors hover:text-emerald-600">Contact</li>
      </ul>

      <!-- Mobile Menu Button -->
      <button class="md:hidden" id="mobile-menu-button" aria-label="Open Menu">
        <i data-lucide="menu" class="h-6 w-6"></i>
      </button>
    </div>

